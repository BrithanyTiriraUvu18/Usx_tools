<odoo>
    <record id="view_wizard_pricelist_form" model="ir.ui.view">
        <field name="name">wizard.pricelist.form</field>
        <field name="model">wizard.pricelist</field>
        <field name="arch" type="xml">
            <form string="Importar Lista de Precios">
                <sheet>
                    <group>
                        <label for="file" class="oe_form_label">Archivo</label>
                        <div class="o_field_widget o_input_widget">
                            <field name="file" filename="file_name" widget="binary" options="{'no_open': True}" class="oe_form_field_input" required="false"/>
                        </div>
                    </group>
                </sheet>
                <footer>
                    <button name="import_data" string="Importar" type="object" class="btn-primary"/>
                    <button name="test_data" string="Test" type="object" class="btn-secondary"/>
                    <button name="export_template" string="Exportar Plantilla" type="object" class="btn-secundary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
