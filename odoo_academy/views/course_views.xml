<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Vista de búsqueda -->
        <record model="ir.ui.view" id="course_view_search">
            <field name="name">academy.course.search</field>
            <field name="model">academy.course</field>
            <field name="arch" type="xml">
                <search string="Buscar Cursos">
                    <field name="name"/>
                    <field name="description"/>
                    <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
                    <filter name="inactive" string="Inactivos" domain="[('active', '=', False)]"/>
                    <group expand="1" string="Agrupar por">
                        <filter name="group_level" string="Nivel" context="{'group_by':'level'}"/>
                    </group>
                </search>
            </field>
        </record>

      <record model="ir.ui.view" id="course_view_form">
       <field name="name">academy.course.pivot</field>
       <field name="model">academy.course</field>
       <field name="arch" type="xml">
        <pivot>
              <field name="level" type="row"/>
              <field name="name" type="row"/>
              <field name="base_price" type="measure"/>
              <field name="additional_fee" type="measure"/>
              <field name="total_price" type="measure"/>
       </pivot>
       </field>
      </record>
        <!-- Vista de formulario -->
        <record id="view_form_course" model="ir.ui.view">
            <field name="name">academy.course.form</field>
            <field name="model">academy.course</field>
            <field name="arch" type="xml">
                <form string="Curso">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="level"/>
                        </group>

                        <group>
                            <field name="base_price"/>
                            <field name="additional_fee"/>
                            <field name="total_price" force_save="1"/>
                        </group>

                        <notebook>
                            <page string="Descripción">
                                <field name="description"/>
                            </page>
                            <page string="Sesiones">
                                <field name="session_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista de árbol -->
        <record id="view_tree_course" model="ir.ui.view">
            <field name="name">academy.course.tree</field>
            <field name="model">academy.course</field>
            <field name="arch" type="xml">
                <tree string="Cursos">
                    <field name="name"/>
                    <field name="level"/>
                    <field name="active"/>
                    <field name="base_price"/>
                    <field name="additional_fee" />
                    <field name="total_price" />
                </tree>
            </field>
        </record>

        <!-- Acción de Ventana -->
        <record id="action_course" model="ir.actions.act_window">
            <field name="name">Cursos</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">academy.course</field>
            
            <!-- aqui añado al pivot-->
            <field name="view_mode">tree,form,pivot</field>
            <field name="search_view_id" ref="course_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Crea tu primer curso
                </p>
            </field>
        </record>

        <!-- Menú -->
        <menuitem id="menu_academy" name="Academia" sequence="1"/>
        <menuitem id="menu_academy_sub" name="Academia" parent="menu_academy" sequence="2"/>
        <menuitem id="menu_academy_course" name="Cursos" parent="menu_academy_sub" action="action_course" sequence="3"/>

    </data>
</odoo>
