<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_form_inherit_session_product" model="ir.ui.view">
        <field name="name">product.template.inherit.session.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- Puedes ponerlo donde quieras, por ejemplo en la pestaña general -->
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="is_session_product"/>
            </xpath>
        </field>
    </record>
</odoo>
