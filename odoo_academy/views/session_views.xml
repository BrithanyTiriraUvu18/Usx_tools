<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Vista de búsqueda -->
        <record model="ir.ui.view" id="session_view_search">
            <field name="name">academy.session.search</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <search string="Buscar Sesiones">
                    <field name="name"/>
                    <field name="course_id"/>
                    <field name="instructor_id"/>
                    <group expand="1" string="Agrupar por">
                        <filter name="group_by_course" string="Curso" context="{'group_by': 'course_id'}"/>
                        <filter name="group_by_instructor" string="Instructor" context="{'group_by': 'instructor_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Vista de formulario -->
        <record model="ir.ui.view" id="session_view_form">
            <field name="name">academy.session.form</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <form string="Session Form">
                    <sheet>
                        <h1><field name="name"/></h1>
                        <group>
                            <group>
                                <field name="course_id"/>
                                <field name="instructor_id"/>
                            </group>
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="duration"/>
                                
                            </group>
                        </group>
                        <notebook>
                            <page string="Estudiantes">
                                <field name="student_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Vista de lista -->
        <record model="ir.ui.view" id="session_view_list">
            <field name="name">academy.session.list</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <tree string="Session List">
                    <field name="name"/>
                    <field name="course_id"/>
                    <field name="instructor_id"/>
                </tree>
            </field>
        </record>

        <!-- Vista de calendario -->
        <record model="ir.ui.view" id="session_view_calendar">
            <field name="name">academy.session.calendar</field>
            <field name="model">academy.session</field>
            <field name="arch" type="xml">
                <calendar string="Calendar View"
                          date_start="start_date"
                          date_stop="end_date"
                          color="instructor_id"
                          mode="month">
                    <field name="name"/>
                    <field name="instructor_id"/>
                </calendar>
            </field>
        </record>

        <!-- Acción de ventana -->
        <record model="ir.actions.act_window" id="session_list_action">
            <field name="name">Sessions</field>
            <field name="res_model">academy.session</field>
            <field name="view_mode">tree,form,calendar</field>
            <field name="search_view_id" ref="session_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create the first session
                </p>
            </field>
        </record>

        <!-- (Opcional) Menú -->
        <menuitem id="menu_academy" name="Academia" sequence="1"/>
        <menuitem id="menu_academy_sub" name="Academia" parent="menu_academy" sequence="2"/>
        <menuitem id="menu_academy_session" name="Sesiones" parent="menu_academy_sub" action="session_list_action" sequence="4"/>

    </data>
</odoo>
