<odoo>
    <record id="view_import_contact_wizard_form" model="ir.ui.view">
        <field name="name">import.contact.wizard.form</field>
        <field name="model">import.contact.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Contacts">

                <sheet>
                    <group>
                        
                        <label for="file" class="oe_form_label">File</label>
                        <div class="o_field_widget o_input_widget">
                            <field name="file" filename="file_name" widget="binary" options="{'no_open': True}" class="oe_form_field_input" required="false"/>
                        </div>
                    </group>
                </sheet>

               
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button name="action_test" type="object" string="Test" class="btn-secondary"/>
                    <button name="action_export_template" type="object" string="Export Template" class="btn-secondary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
