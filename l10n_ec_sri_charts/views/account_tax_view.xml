<?xml version="1.0" encoding="utf-8" ?>
<odoo>
        <record id="account_tax_code_form" model="ir.ui.view">
            <field name="name">account.tax.code.form</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='tax_group_id']" position="after">
                    <field name="type" invisible="1" />
                    <field name="code" required="type =='ret_ir'" />
                    <field name="l10n_ec_code_applied" groups="base.group_no_one" />

                    <!-- <field name="type" /> -->
                    <field name="code_edocument" />
                </xpath>
            </field>
        </record>

</odoo>
