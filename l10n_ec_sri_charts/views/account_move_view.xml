<?xml version='1.0' encoding='utf-8' ?>
<odoo>
        <!-- Form View -->
        <record id="view_account_move_form_inherit" model="ir.ui.view">
            <field name="name">view.account.move.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">
                <xpath expr="//div[@name='journal_div']" position="after">
                    <field
                    name="tax_support_id"
                    invisible="move_type  in ('out_invoice', 'out_refund','entry', 'out_receipt', 'in_receipt')"
                    required="move_type in  ('in_invoice', 'in_refund')"
                />
                    <field
                    name="voucher_type_ats"
                    invisible="move_type in ('entry', 'out_receipt', 'in_receipt')"
                    required="move_type in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')"
                />
                    <field
                    name="amended_invoice_id"
                    readonly="state != 'draft'"
                    invisible="move_type != 'out_refund'"
                    required="move_type == 'out_refund'"
                    options="{'no_create': True, 'no_create_edit': True}"
                />
                </xpath>
            </field>
        </record>
</odoo>
